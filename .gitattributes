# Enforce LF endings for all text files, in the repository and in the
# working tree, regardless of any local core.autocrlf setting. This keeps
# scripts (gradlew) runnable on Linux/WSL/CI.
* text=auto eol=lf

# Windows batch scripts need CRLF to run correctly.
*.bat text eol=crlf

# Binary files — never touch line endings.
*.jar binary
*.png binary
*.zip binary
